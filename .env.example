# ============================================================================
# APEX Trading Intelligence System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================================

# --- System ---
ENVIRONMENT=paper
LOG_LEVEL=INFO
SYSTEM_NAME=APEX

# --- LLM (AutoGen agents) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...

# Dhan API Credentials
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Upstash Redis DB1 — Live State (MARKET_REGIME, TRADE_SIGNALS, POSITIONS, etc.)
UPSTASH_LIVE_STATE_URL=https://desired-stud-34827.upstash.io
UPSTASH_LIVE_STATE_TOKEN=your_db1_token_here

# Upstash Redis DB2 — Intelligence (CONFIG, STRATEGY, HISTORICAL)
UPSTASH_INTELLIGENCE_URL=https://precious-mallard-35072.upstash.io
UPSTASH_INTELLIGENCE_TOKEN=your_db2_token_here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TICKS=apex.ticks
KAFKA_TOPIC_SIGNALS=apex.signals
KAFKA_TOPIC_ORDERS=apex.orders

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apex_trading
DB_USER=apex
DB_PASSWORD=your_db_password_here

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_secret_key_here

# Logging
LOG_FILE=logs/apex.log

# Trading Mode
TRADING_MODE=paper  # paper or live
MAX_DAILY_LOSS_PCT=2.0
MAX_POSITION_SIZE_PCT=0.5

# --- Global Market Data ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key

# --- Risk Limits (HARD LIMITS) ---
MAX_RISK_PER_TRADE_PCT=2.0
MAX_PORTFOLIO_DRAWDOWN_PCT=15.0
MIN_AGENT_CONSENSUS=3
VIX_KILL_SWITCH_THRESHOLD=25.0
MAX_SECTOR_EXPOSURE_PCT=30.0
MAX_LEVERAGE=2.0

# --- Capital ---
TOTAL_CAPITAL_INR=1000000
CORE_ALLOCATION_PCT=60.0
SATELLITE_ALLOCATION_PCT=40.0

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change_this_to_random_string
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password

# --- Alerts ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
SENDGRID_API_KEY=your_sendgrid_key
ALERT_EMAIL_TO=you@yourdomain.com

# --- Backtesting ---
BACKTEST_START_DATE=2015-01-01
BACKTEST_END_DATE=2025-12-31
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION_PCT=0.03
BACKTEST_SLIPPAGE_PCT=0.05

# --- Feature Flags ---
ENABLE_LIVE_TRADING=false
ENABLE_OPTIONS_TRADING=false
ENABLE_FUTURES_TRADING=true
ENABLE_CRYPTO_SIGNALS=true
ENABLE_GLOBAL_MACRO=true
ENABLE_ML_REGIME_DETECTION=true
ENABLE_ZERO_DTE=false
ENABLE_LEARNING_ENGINE=true
PAPER_TRADE_MODE=true
