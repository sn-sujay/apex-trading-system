# ============================================================
# APEX Trading Intelligence System -- Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- System ---
ENVIRONMENT=paper
LOG_LEVEL=INFO
SYSTEM_NAME=APEX

# --- LLM (AutoGen agents) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...

# --- Zerodha Kite (Primary Indian Broker) ---
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token
KITE_USER_ID=your_user_id

# --- Upstox (Fallback Indian Broker) ---
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_ACCESS_TOKEN=your_upstox_access_token

# --- Global Market Data ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key

# --- TimescaleDB ---
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_DB=apex_trading
TIMESCALEDB_USER=apex_user
TIMESCALEDB_PASSWORD=your_db_password
DATABASE_URL=postgresql://apex_user:your_db_password@localhost:5432/apex_trading

# --- Apache Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MARKET_TICKS=market.ticks
KAFKA_TOPIC_AGENT_SIGNALS=agent.signals
KAFKA_TOPIC_DECISIONS=decisions.output
KAFKA_TOPIC_RISK_ALERTS=risk.alerts
KAFKA_TOPIC_ORDERS=execution.orders
KAFKA_CONSUMER_GROUP=apex-consumers

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# --- Risk Limits (HARD LIMITS) ---
MAX_RISK_PER_TRADE_PCT=2.0
MAX_DAILY_LOSS_PCT=5.0
MAX_PORTFOLIO_DRAWDOWN_PCT=15.0
MAX_POSITION_SIZE_PCT=10.0
MIN_AGENT_CONSENSUS=3
VIX_KILL_SWITCH_THRESHOLD=25.0
MAX_SECTOR_EXPOSURE_PCT=30.0
MAX_LEVERAGE=2.0

# --- Capital ---
TOTAL_CAPITAL_INR=1000000
CORE_ALLOCATION_PCT=60.0
SATELLITE_ALLOCATION_PCT=40.0

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change_this_to_random_string
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password

# --- Alerts ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
SENDGRID_API_KEY=your_sendgrid_key
ALERT_EMAIL_TO=you@yourdomain.com

# --- Backtesting ---
BACKTEST_START_DATE=2015-01-01
BACKTEST_END_DATE=2025-12-31
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION_PCT=0.03
BACKTEST_SLIPPAGE_PCT=0.05

# --- Feature Flags ---
ENABLE_LIVE_TRADING=false
ENABLE_OPTIONS_TRADING=false
ENABLE_FUTURES_TRADING=true
ENABLE_CRYPTO_SIGNALS=true
ENABLE_GLOBAL_MACRO=true
ENABLE_ML_REGIME_DETECTION=true
ENABLE_ZERO_DTE=false
ENABLE_LEARNING_ENGINE=true
PAPER_TRADE_MODE=true
